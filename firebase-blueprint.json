{
  "entities": {
    "MergeJob": {
      "title": "Merge Job",
      "description": "Represents a merge operation in the queue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "prId": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "resolving_conflicts", "running_tests", "completed", "failed"] },
        "progress": { "type": "number" },
        "logs": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "isBatch": { "type": "boolean" },
        "batchPrIds": { "type": "array", "items": { "type": "string" } },
        "batchName": { "type": "string" },
        "priority": { "type": "string", "enum": ["standard", "high"] }
      },
      "required": ["id", "status", "progress", "createdAt"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Represents a Git branch.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["master", "project", "release"] },
        "lastCommit": { "type": "string" },
        "status": { "type": "string", "enum": ["stable", "active", "merged", "stale"] },
        "lastMergedAt": { "type": "number" }
      },
      "required": ["id", "name", "type", "status"]
    }
  },
  "firestore": {
    "mergeQueue": {
      "schema": "MergeJob",
      "description": "The active merge queue."
    },
    "branches": {
      "schema": "Branch",
      "description": "Tracked branches."
    }
  }
}
