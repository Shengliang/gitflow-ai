{
  "entities": {
    "Branch": {
      "title": "Branch",
      "description": "A git branch in the workflow",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Branch name" },
        "type": { "type": "string", "enum": ["master", "project", "release"], "description": "Type of branch" },
        "teamId": { "type": "string", "description": "Associated team ID" },
        "lastMergedAt": { "type": "number", "description": "Timestamp of last merge" }
      },
      "required": ["name", "type"]
    },
    "PullRequest": {
      "title": "PullRequest",
      "description": "A pull request in the system",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "PR title" },
        "author": { "type": "string", "description": "Author name" },
        "authorUid": { "type": "string", "description": "Author Firebase UID" },
        "sourceBranch": { "type": "string", "description": "Source branch name" },
        "targetBranch": { "type": "string", "description": "Target branch name" },
        "status": { "type": "string", "enum": ["open", "merging", "merged", "conflict", "failed_tests"], "description": "Current status" },
        "createdAt": { "type": "number", "description": "Creation timestamp" },
        "conflictDetails": { "type": "string", "description": "Details if in conflict" },
        "testResults": { "type": "string", "description": "Results of tests" }
      },
      "required": ["title", "author", "authorUid", "sourceBranch", "targetBranch", "status", "createdAt"]
    },
    "MergeJob": {
      "title": "MergeJob",
      "description": "An active AI merge job",
      "type": "object",
      "properties": {
        "prId": { "type": "string", "description": "Associated PR ID" },
        "status": { "type": "string", "enum": ["queued", "resolving_conflicts", "running_tests", "completed", "failed"], "description": "Job status" },
        "progress": { "type": "number", "description": "Progress percentage" },
        "logs": { "type": "array", "items": { "type": "string" }, "description": "Execution logs" },
        "aiResolution": { "type": "string", "description": "AI generated resolution" }
      },
      "required": ["prId", "status", "progress", "logs"]
    },
    "Team": {
      "title": "Team",
      "description": "An engineering team",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Team name" },
        "engineers": { "type": "array", "items": { "type": "string" }, "description": "List of engineer names" }
      },
      "required": ["name", "engineers"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User display name" },
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "engineer"], "description": "User role" }
      },
      "required": ["displayName", "email", "role"]
    }
  },
  "firestore": {
    "/branches/{branchId}": { "schema": "Branch", "description": "Collection of branches" },
    "/pullRequests/{prId}": { "schema": "PullRequest", "description": "Collection of pull requests" },
    "/mergeJobs/{jobId}": { "schema": "MergeJob", "description": "Collection of active merge jobs" },
    "/teams/{teamId}": { "schema": "Team", "description": "Collection of teams" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" }
  }
}
