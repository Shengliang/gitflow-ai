rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: mergeQueue
    // Document ID: jobId
    // Fields:
    //   - id: string (required)
    //   - prId: string
    //   - status: string (required, enum: ["queued", "resolving_conflicts", "running_tests", "completed", "failed"])
    //   - progress: number (required, 0-100)
    //   - logs: list (required, strings)
    //   - createdAt: number (required)
    //   - isBatch: bool
    //   - batchPrIds: list
    //   - batchName: string
    //   - priority: string
    //
    // Collection: branches
    // Document ID: branchId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - type: string (required, enum: ["master", "project", "release"])
    //   - lastCommit: string
    //   - status: string (required, enum: ["stable", "active", "merged", "stale"])
    //   - lastMergedAt: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "shengliang.song@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidMergeJob(data) {
      let validStatuses = ["queued", "resolving_conflicts", "running_tests", "completed", "failed"];
      return hasRequiredFields(['id', 'status', 'progress', 'createdAt']) &&
             data.id is string &&
             data.status in validStatuses &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.logs is list &&
             data.createdAt is number;
    }

    function isValidBranch(data) {
      let validTypes = ["master", "project", "release"];
      let validStatuses = ["stable", "active", "merged", "stale"];
      return hasRequiredFields(['id', 'name', 'type', 'status']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 &&
             data.type in validTypes &&
             data.status in validStatuses;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /mergeQueue/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMergeJob(request.resource.data);
      allow update: if isAuthenticated() && isValidMergeJob(request.resource.data);
      allow delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBranch(request.resource.data);
      allow update: if isAuthenticated() && isValidBranch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == userId) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();
    }
  }
}
